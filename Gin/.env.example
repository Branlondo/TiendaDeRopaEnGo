# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Copia este archivo como ".env" y rellena con tus credenciales reales.
# NUNCA subas el archivo ".env" a Git (ya está en .gitignore).

DB_HOST=localhost
DB_PORT=5432
DB_USER=tienda_user
DB_PASSWORD=cambia_esta_clave
DB_NAME=tienda_db
DB_SSLMODE=disable

# ── Sesiones ──────────────────────────────────────────────────────────────────
# Clave secreta que firma las cookies. Debe ser larga y aleatoria.
SESSION_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria
